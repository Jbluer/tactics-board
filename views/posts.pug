doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    link(rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      integrity="sha256-fx038NkLY4U1TCrBDiu5FWPEa9eiZu01EiLryshJbCo="
      crossorigin="anonymous")
    link(rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.0/font/bootstrap-icons.css")
    link(rel="stylesheet" href="style.css")
    title 陣略棋戦術交流掲示板
  body(data-bs-theme=currentTheme)
    nav.navbar.fixed-top.bg-primary
      div.container-fluid
        h1.text-light.navbar-brand.mx-auto 陣略棋戦術交流掲示板
          i.bi-chat-dots-fill.ms-1
        div.dropdown
          button.btn.btn-outline-light.dropdown-toggle(type="button" id="menu" data-bs-toggle="dropdown" aria-expanded="false") #{user}
            i.bi-gear-fill.ms-1
          ul.dropdown-menu.dropdown-menu-end(aria-labelledby="menu")
            li
              - const changeThemeText = (currentTheme === 'light' ? 'ダークモードに切り替え' : 'ライトモードに切り替え');
              a.dropdown-item(href="/changeTheme") #{changeThemeText}
              a.dropdown-item(href="/logout") ログアウト

    div.main-layout
      div.chat-panel
        div.posts-container#posts-container
          each post in posts
            - const cardClass = (user === post.postedBy ? 'card my-3 border-primary' : 'card my-3')
            div(class=cardClass)
              div.card-body
                div.d-flex.justify-content-between
                  h5.card-title #{post.postedBy}
                    if post.postedBy === 'admin'
                      i.bi-patch-check-fill.ms-1
                  - const tooltipTitle = `<small>${post.absoluteCreatedAt}</small>`
                  small.card-text.float-end(data-bs-toggle="tooltip" data-bs-placement="top" data-bs-html="true" title=tooltipTitle) #{post.relativeCreatedAt}
                - const boardMatch = post.content.match(/\[board:(\[.*?\])\]/s)
                - const boardPieces = boardMatch ? boardMatch[1] : null
                - const displayContent = post.content.replace(/\[board:[^\]]*\]/g, '').trim()
                p.card-text.lead #{displayContent}
                if boardPieces
                  div.mt-2
                    canvas.board-preview-canvas(
                      width="180" height="180"
                      data-pieces=boardPieces
                      style="border-radius:4px; box-shadow:0 1px 4px rgba(0,0,0,0.2); display:block;")
                    button.btn.btn-outline-secondary.btn-sm.mt-1.btn-load-board(
                      type="button"
                      data-pieces=boardPieces) 盤面に反映
                      i.bi-arrow-left-circle.ms-1
              - const isDeletable = (user === post.postedBy || user === 'admin')
              if isDeletable
                div.card-footer.d-flex.justify-content-end
                  form(method="post" action="/posts/delete")
                    input(type="hidden" name="id" value=post.id)
                    button(type="submit").btn.btn-outline-danger.btn-sm
                      i.bi-trash

        div.chat-input-area.p-3.bg-body.border-top
          form(method="post" action="/posts" name="message-form").container-fluid.row.g-2
            div.col-12
              textarea(name="content" rows="3" placeholder="Ctrl(Command)+Enterで送信できます").form-control
              input(type="hidden" name="oneTimeToken" value=oneTimeToken)
            div.col-12
              button(type="button").btn.btn-outline-secondary.btn-sm#btn-attach-board
                i.bi-grid-3x3.me-1
              | 盤面を添付
              button(type="submit").btn.btn-primary.float-end
                i.bi-send

      div.board-panel
        div.board-header.p-2.border-bottom.d-flex.align-items-center.justify-content-between
          span.fw-bold.small 盤面
          div.d-flex.gap-1
            button.btn.btn-sm.btn-outline-secondary#btn-clear リセット
        div.board-area
          div#board-container
            canvas#board-canvas
        div.piece-palette.p-2.border-top
          div.small.text-muted.mb-1 駒パレット（クリックで選択）
          div.d-flex.flex-wrap.gap-1#piece-palette
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
      integrity="sha256-qlPVgvl+tZTCpcxYJFdHB/m6mDe84wRr+l81VoYPTgQ="
      crossorigin="anonymous")
    script(src="boardchat.js")